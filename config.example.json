  "entry_pricing": {
    "price_side": "other"
  },
  "exit_pricing": {
    "price_side": "other"
  },
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "market",
    "stoploss_on_exchange": false,
    "emergency_exit": "market"
  },
  "order_time_in_force": {
    "entry": "GTC",
    "exit": "GTC"
  },
  "exchange": {
    "name": "kraken",
    "key": "YOUR_KRAKEN_API_KEY_HERE",
    "secret": "YOUR_KRAKEN_API_SECRET_HERE",
    "pair_blacklist": [],
    "ccxt_config": {
      "enableRateLimit": true
    },
    "ccxt_async_config": {
      "enableRateLimit": true
    },
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT",
