  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "telegram": {
    "enabled": true,
    "token": "YOUR_TOKEN_HERE",
    "chat_id": "YOUR_CHAT_ID_HERE",
    "trade": {
      "entry": true,
      "exit": true
    }
  },
  "api_server": {
    "enabled": true,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8080,
    "verbosity": "info",
    "enable_openapi": true,
    "jwt_secret_key": "YOUR_JWT_SECRET_HERE",
    "ws_token": "YOUR_WS_TOKEN_HERE",
    "username": "freqtrader",
    "password": "YOUR_PASSWORD_HERE"
  },
  "strategy": "UltimateAlphaV16",
  "bot_name": "UltimateAlphaV16",
  "initial_state": "running",
  "internals": {
    "process_throttle_secs": 5
  },
  "datadir": "/Users/YOUR_USERNAME/vibe_os/user_data/data/kraken",
  "dataformat_ohlcv": "feather",
  "dataformat_trades": "feather",
  "freqai": {
    "enabled": false,
    "train_period_days": 40,
    "backtest_period_days": 30,
    "live_retrain_hours": 6,
    "identifier": "ultimate_alpha_hybrid_v15",
    "feature_parameters": {
      "include_timeframes": [
        "1h",
        "4h"
      ],
      "include_corr_pairlist": [
        "BTC/USDT",
        "ETH/USDT"
      ]
    },
    "model_training_parameters": {
      "n_estimators": 1000,
      "learning_rate": 0.04,
      "max_depth": 9
    },
    "data_split_parameters": {
      "test_size": 0.2
    }
  },
  "hyperopt": {
    "hyperopt_loss": "MultiMetricHyperOptLoss"
  }
